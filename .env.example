# ============================================
# 文澜智作 - 环境变量配置
# ============================================

# ========== Supabase 数据库（必需） ==========
# 从 Supabase 控制台获取：Settings → API
COZE_SUPABASE_URL=https://your-project.supabase.co
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========== 数据库连接（可选，自动从上面获取） ==========
# 如果上面两个没有，会自动使用这些
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ========== 邮件发送（可选，用于邮箱注册验证码） ==========
# 推荐使用 QQ 邮箱或 163 邮箱的 SMTP 服务
# QQ 邮箱：设置 → 账户 → POP3/SMTP服务 → 生成授权码
# 163 邮箱：设置 → POP3/SMTP/IMAP → 开启服务 → 获取授权码

SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=your-email@qq.com
SMTP_PASS=your-email-auth-code

# ========== 微信公众号（可选，用于推送文章到公众号） ==========
# 在微信公众平台获取：设置与开发 → 基本配置
WECHAT_APP_ID=wx1234567890abcdef
WECHAT_APP_SECRET=your-app-secret

# ========== 微信登录（可选） ==========
# 如果使用微信扫码登录，需要配置微信公众号
# 需要在微信公众平台设置授权回调域名为你的网站域名
